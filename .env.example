# Kopyala: cp .env.example .env.local
# .env.local dosyasını asla commit etme.

# Yerel geliştirme: magic link bu adrese döner (npm run dev portu ile aynı olmalı)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Canlı site: NEXT_PUBLIC_SITE_URL=https://munzurcevredernegi.net

RESEND_API_KEY=re_your_key_here
# İletişim formu alıcısı: lib/organization.ts → munzurcevredernegi@gmail.com
RESEND_FROM=Munzur Çevre Derneği <onboarding@resend.dev>

# Supabase — Project Settings → API (site URL değil, xxx.supabase.co olmalı!)
# Anahtar satırına yorum yazmayın (# ile); ayrı satıra alın.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SADECE server — asla client bundle'a ekleme
SUPABASE_SERVICE_ROLE_KEY=

# Admin — yedek (asıl liste: Supabase admin_users tablosu, bkz. docs/supabase/auth-admin.md)
ADMIN_EMAIL=munzurcevredernegi@gmail.com
# npm run dev iken /admin girişi otomatik atlanır; canlıda /login ile şifre gerekir.
# AUTH_SECRET=uzun-rastgele-bir-deger
